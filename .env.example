# ==============================================================================
# DeNotenman — environment template
# Copy to .env and fill in. Never commit .env.
# ==============================================================================

# --- Runtime ---
NODE_ENV=development

# --- Database ---
DATABASE_URL=postgresql://denotenman:denotenman@localhost:5432/denotenman?schema=public

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- Storage (Cloudflare R2, S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=denotenman-media
R2_PUBLIC_URL=

# --- Mail ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM="DeNotenman <no-reply@denotenman.nl>"

# --- App URLs ---
STOREFRONT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
API_URL=http://localhost:4000

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=info

# --- Seed (development only) ---
SEED_OWNER_EMAIL=owner@denotenman.nl
SEED_OWNER_PASSWORD=
SEED_ADMIN_EMAIL=admin@denotenman.nl
SEED_ADMIN_PASSWORD=
